# Normalize line endings so source is byte-identical across Windows/Linux CI.
* text=auto eol=lf

# Windows-only scripts stay CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary — never touch, never diff as text
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.wav  binary
*.ogg  binary
*.mp3  binary
*.glb  binary
*.gltf binary
*.db   binary
*.sqlite binary
*.msgpack binary

# Golden-master replay logs and art — Git LFS (roadmap §4)
# (LFS filters activate once `git lfs install` is run; harmless until then)
/replays/**  filter=lfs diff=lfs merge=lfs -text
*.png  filter=lfs diff=lfs merge=lfs -text
*.psd  filter=lfs diff=lfs merge=lfs -text
